generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  owner
  manager
  cashier
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  memberships  StoreMember[]
}

model Store {
  id        String        @id @default(cuid())
  name      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  members   StoreMember[]
  changes   SyncChange[]
}

model StoreMember {
  id        String     @id @default(cuid())
  userId    String
  storeId   String
  role      MemberRole @default(owner)
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId])
}

model SyncChange {
  id         String   @id
  storeId    String
  branchId   String?
  deviceId   String
  entityType String
  entityId   String
  operation  String
  payload    Json
  createdAt  DateTime
  receivedAt DateTime @default(now())
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
  @@index([storeId, entityType, entityId])
}
